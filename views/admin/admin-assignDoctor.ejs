<% layout("layouts/admin/boilerplate.ejs") %>

<div class="admin-page-container" style="max-width: 700px; margin-top: 2rem;">
  <!-- Header -->
  <div class="profile-header-card" style="padding: 2rem; margin-bottom: 1.5rem;">
    <div class="profile-avatar-section" style="gap: 1rem;">
      <div class="profile-avatar admin-avatar" style="width: 64px; height: 64px; font-size: 1.5rem;">
        <i class="fa-solid fa-user-doctor"></i>
      </div>
      <div class="profile-title">
        <h2 style="font-size: 1.5rem;">Assign Doctor</h2>
        <span class="profile-badge admin-badge">New Consultation</span>
      </div>
    </div>
  </div>

  <!-- Patient Info Card -->
  <div style="background: var(--bg-secondary); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; border: 1px solid var(--border-color);">
    <h5 style="color: var(--text-secondary); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1rem;">
      <i class="fa-solid fa-user-injured me-2"></i>Patient Details
    </h5>
    <div style="display: flex; align-items: center; gap: 1rem;">
      <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #0ea5e9 0%, #14b8a6 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 1.25rem;">
        <i class="fa-solid fa-user"></i>
      </div>
      <div>
        <h4 style="margin: 0;"><%= patient.name %></h4>
        <p style="color: var(--text-secondary); margin: 0; font-size: 0.9rem;">Age: <%= patient.age %> | Aadhaar: <%= patient.aadhar %></p>
      </div>
    </div>
  </div>

  <!-- Assign Doctor Form -->
  <div style="background: var(--bg-secondary); border-radius: 24px; padding: 2.5rem; box-shadow: var(--shadow-xl); border: 1px solid var(--border-color); position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%);"></div>

    <p style="color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 1.5rem;">
      <i class="fa-solid fa-circle-info me-2" style="color: var(--primary-blue);"></i>
      Select a doctor and specify the disease/symptoms for this consultation.
    </p>

<form method="post" action="/assign-doctor/<%= patient._id %>">
      <!-- Disease -->
      <div class="mb-4">
        <label class="form-label" style="font-weight: 600; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">
          <i class="fa-solid fa-virus me-2" style="color: #8b5cf6;"></i>Disease / Symptoms <span style="color: #ef4444;">*</span>
        </label>
        <input type="text" name="disease" class="form-control" placeholder="Enter disease or symptoms" required
          value="<%= patient.disease %>"
          style="border: 2px solid var(--border-color); border-radius: 12px; padding: 0.875rem 1.25rem; font-size: 1rem; transition: var(--transition); background: var(--bg-secondary);">
      </div>

      <!-- Doctor -->
      <div class="mb-4">
        <label class="form-label" style="font-weight: 600; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">
          <i class="fa-solid fa-user-doctor me-2" style="color: #8b5cf6;"></i>Select Doctor <span style="color: #ef4444;">*</span>
        </label>
        <select name="doctorId" class="form-control" required
          style="border: 2px solid var(--border-color); border-radius: 12px; padding: 0.875rem 1.25rem; font-size: 1rem; transition: var(--transition); background: var(--bg-secondary); appearance: auto;">
          <option value="" disabled selected>Select a doctor</option>
          <% doctors.forEach(d => { %>
            <option value="<%= d._id %>"><%= d.name %> — <%= d.specialization %></option>
          <% }) %>
        </select>
      </div>

      <!-- Appointment Date -->
      <div class="mb-4">
        <label class="form-label" style="font-weight: 600; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">
          <i class="fa-solid fa-calendar me-2" style="color: #8b5cf6;"></i>Appointment Date <span style="color: #ef4444;">*</span>
        </label>
        <input type="date" name="appointmentDate" class="form-control" required
          style="border: 2px solid var(--border-color); border-radius: 12px; padding: 0.875rem 1.25rem; font-size: 1rem; transition: var(--transition); background: var(--bg-secondary);">
      </div>

      <!-- Info Alert -->
      <div style="background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.3); border-radius: 12px; padding: 1rem; margin-bottom: 1.5rem;">
        <p style="margin: 0; color: #3b82f6; font-size: 0.9rem;">
          <i class="fa-solid fa-info-circle me-2"></i>
          This will create a new appointment with the selected doctor. The previous consultation will be moved to history after completion.
        </p>
      </div>

      <!-- Actions -->
      <div class="d-flex flex-wrap gap-3">
        <a href="/patient-profile/<%= patient._id %>/view" class="btn btn-secondary" style="background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%); border: none; padding: 0.875rem 1.75rem; border-radius: 12px; font-weight: 600; color: white; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
          <i class="fa-solid fa-arrow-left"></i> Back to Profile
        </a>
        <button type="submit" class="btn btn-primary" style="padding: 0.875rem 2rem; font-size: 1rem; border-radius: 12px; background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%); border: none; box-shadow: var(--shadow-md); transition: var(--transition); display: inline-flex; align-items: center; gap: 0.5rem;">
          <i class="fa-solid fa-user-plus"></i> Assign Doctor
        </button>
      </div>
    </form>
  </div>
</div>

<style>
  .admin-page-container .form-control:focus {
    outline: none;
    border-color: #8b5cf6 !important;
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1) !important;
    transform: translateY(-1px);
  }
  .admin-page-container button[type="submit"]:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl) !important;
  }
  .admin-page-container a.btn-secondary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    color: white;
  }
  @media (max-width: 768px) {
    .admin-page-container {
      margin-top: 1rem !important;
      padding: 0 1rem;
    }
    .admin-page-container .profile-header-card {
      padding: 1.5rem !important;
    }
    .admin-page-container > div:last-child {
      padding: 1.5rem !important;
    }
  }
</style>
