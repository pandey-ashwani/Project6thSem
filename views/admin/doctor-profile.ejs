<% layout("layouts/admin/boilerplate.ejs") %>

<div class="doctor-profile-container">
  <!-- Detail Header Card -->
  <div class="profile-header-card">
    <div class="profile-avatar-section">
      <div class="profile-avatar admin-avatar">
        <i class="fa-solid fa-user-doctor"></i>
      </div>
      <div class="profile-title">
        <h2><%= doctor.name %></h2>
        <span class="profile-badge admin-badge"><%= doctor.specialization || 'Doctor' %></span>
      </div>
    </div>
    <button type="button" class="btn-edit" data-bs-toggle="modal" data-bs-target="#editDoctorModal">
      <i class="fa-solid fa-pen-to-square"></i> Update
    </button>
  </div>

  <!-- Info Grid -->
  <div class="profile-section-title">Doctor Information</div>
  <div class="profile-info-grid">
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-user"></i></div>
      <div class="info-content">
        <label>Name</label>
        <p><%= doctor.name %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-envelope"></i></div>
      <div class="info-content">
        <label>Email</label>
        <p><%= doctor.email %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-phone"></i></div>
      <div class="info-content">
        <label>Contact Number</label>
        <p><%= doctor.phone %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-graduation-cap"></i></div>
      <div class="info-content">
        <label>Qualifications</label>
        <p><%= doctor.qualification || 'N/A' %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-briefcase-medical"></i></div>
      <div class="info-content">
        <label>Specialization</label>
        <p><%= doctor.specialization || 'N/A' %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-hospital"></i></div>
      <div class="info-content">
        <label>Hospital</label>
        <p><%= doctor.hospital %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-location-dot"></i></div>
      <div class="info-content">
        <label>District</label>
        <p><%= doctor.district %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon admin-icon"><i class="fa-solid fa-map"></i></div>
      <div class="info-content">
        <label>State</label>
        <p><%= doctor.state %></p>
      </div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editDoctorModal" tabindex="-1" aria-labelledby="editDoctorModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editDoctorModalLabel">
          <i class="fa-solid fa-pen-to-square me-2"></i>Update Doctor
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="#" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" class="form-control" value="<%= doctor.name %>">
          </div>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" value="<%= doctor.email %>">
          </div>
          <div class="mb-3">
            <label class="form-label">Contact Number</label>
            <input type="number" class="form-control" value="<%= doctor.phone %>">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

