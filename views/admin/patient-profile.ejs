<% layout("layouts/admin/boilerplate.ejs") %>

<%
  // Get active consultation
  let activeConsultation = null;
  let currentDoctor = null;
  if (patient.consultations && patient.consultations.length > 0) {
    activeConsultation = patient.consultations.find(c => c.status === 'active');
    if (activeConsultation) {
      currentDoctor = activeConsultation;
    }
  }
%>

<div class="doctor-profile-container">
  <!-- Detail Header Card -->
  <div class="profile-header-card">
    <div class="profile-avatar-section">
      <div class="profile-avatar" style="background: linear-gradient(135deg, #0ea5e9 0%, #14b8a6 100%);">
        <i class="fa-solid fa-user-injured"></i>
      </div>
      <div class="profile-title">
        <h2><%= patient.name %></h2>
        <span class="profile-badge" style="background: linear-gradient(135deg, #0ea5e9 0%, #14b8a6 100%);">Patient</span>
      </div>
    </div>
    <div style="display: flex; gap: 0.5rem;">
      <a href="/assign-doctor/<%= patient._id %>" class="btn-edit" style="background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%);">
        <i class="fa-solid fa-user-doctor"></i> Re-assign Doctor
      </a>
    </div>
  </div>

  <!-- Info Grid -->
  <div class="profile-section-title">Patient Information</div>
  <div class="profile-info-grid">
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-user"></i>
      </div>
      <div class="info-content">
        <label>Name</label>
        <p><%= patient.name %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-cake-candles"></i>
      </div>
      <div class="info-content">
        <label>Age</label>
        <p><%= patient.age %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-phone"></i>
      </div>
      <div class="info-content">
        <label>Contact Number</label>
        <p><%= patient.username %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-virus"></i>
      </div>
      <div class="info-content">
        <label>Current Disease</label>
        <p><%= patient.disease || 'N/A' %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(139, 92, 246, 0.1); color: #8b5cf6;">
        <i class="fa-solid fa-user-doctor"></i>
      </div>
      <div class="info-content">
        <label>Current Doctor</label>
        <p><%= currentDoctor ? currentDoctor.doctorName : (doctor ? doctor.name : 'Not assigned') %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-calendar"></i>
      </div>
      <div class="info-content">
        <label>Consultation Start</label>
        <p><%= currentDoctor ? new Date(currentDoctor.startDate).toLocaleDateString() : 'N/A' %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-hospital"></i>
      </div>
      <div class="info-content">
        <label>Hospital</label>
        <p><%= patient.hospital %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-location-dot"></i>
      </div>
      <div class="info-content">
        <label>District</label>
        <p><%= patient.district %></p>
      </div>
    </div>
  </div>

<!-- Appointments Section (Current/Scheduled) -->
  
<% if (patient.appointments && patient.appointments.length > 0) { %>
  <div class="profile-section-title" style="margin-top: 2rem;">
    <i class="fa-solid fa-calendar-check me-2"></i>Appointments & Visits
  </div>
  <div style="background: var(--bg-secondary); border-radius: 16px; padding: 1.5rem; border: 1px solid var(--border-color);">
    
    <% 
      const sortedAppointments = [...patient.appointments].sort((a, b) => new Date(b.appointmentDate) - new Date(a.appointmentDate));
    %>

    <% sortedAppointments.forEach((appointment, index) => { %>

      <% 
        // 🔥 FIND RELATED CONSULTATION
        const relatedConsultation = patient.consultations?.find(c =>
          c.doctor?.toString() === appointment.doctor?.toString() &&
          new Date(c.startDate).toDateString() === new Date(appointment.appointmentDate).toDateString()
        );

        // 🔥 FINAL STATUS LOGIC
        let finalStatus = appointment.status;

        if (relatedConsultation && relatedConsultation.status === "completed") {
          finalStatus = "completed";
        }
      %>

      <div style="display: flex; align-items: center; padding: 1rem; <%= index > 0 ? 'border-top: 1px solid var(--border-color);' : '' %>">
        
        <!-- ICON -->
        <div style="width: 40px; height: 40px; border-radius: 10px; background: 
          <%= finalStatus === 'pending' ? 'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)' 
          : finalStatus === 'today' ? 'linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)' 
          : finalStatus === 'completed' ? 'rgba(100, 100, 100, 0.2)' 
          : 'rgba(239, 68, 68, 0.2)' %>; 
          display: flex; align-items: center; justify-content: center; color: white; margin-right: 1rem;">

          <i class="fa-solid <%= finalStatus === 'pending' ? 'fa-clock' 
            : finalStatus === 'today' ? 'fa-calendar-day' 
            : finalStatus === 'completed' ? 'fa-check' 
            : 'fa-times' %>"></i>
        </div>

        <!-- CONTENT -->
        <div style="flex: 1;">
          <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
            <strong><%= appointment.disease %></strong>

            <span style="font-size: 0.75rem; padding: 0.125rem 0.5rem; border-radius: 20px; 
              background: <%= finalStatus === 'pending' ? 'rgba(245, 158, 11, 0.1)' 
              : finalStatus === 'today' ? 'rgba(59, 130, 246, 0.1)' 
              : finalStatus === 'completed' ? 'rgba(100, 100, 100, 0.1)' 
              : 'rgba(239, 68, 68, 0.1)' %>; 
              color: <%= finalStatus === 'pending' ? '#f59e0b' 
              : finalStatus === 'today' ? '#3b82f6' 
              : finalStatus === 'completed' ? '#666' 
              : '#ef4444' %>;">
              
              <%= finalStatus === 'pending' ? 'Pending' 
                : finalStatus === 'today' ? 'Today' 
                : finalStatus === 'completed' ? 'Completed' 
                : 'Cancelled' %>
            </span>
          </div>

          <p style="color: var(--text-secondary); margin: 0; font-size: 0.9rem;">
            <i class="fa-solid fa-user-doctor me-1"></i><%= appointment.doctorName %> | 
            <i class="fa-solid fa-calendar me-1"></i><%= new Date(appointment.appointmentDate).toLocaleDateString() %>
          </p>
        </div>

      </div>
    <% }) %>
  </div>
<% } %>

  <!-- Consultation History -->
  <% if (patient.consultations && patient.consultations.length > 0) { %>
  <div class="profile-section-title" style="margin-top: 2rem;">
    <i class="fa-solid fa-clock-rotate-left me-2"></i>Consultation History
  </div>
  <div style="background: var(--bg-secondary); border-radius: 16px; padding: 1.5rem; border: 1px solid var(--border-color);">
    <% 
      // Sort consultations by startDate descending (newest first)
      const sortedConsultations = [...patient.consultations].sort((a, b) => new Date(b.startDate) - new Date(a.startDate));
    %>
    <% sortedConsultations.forEach((consultation, index) => { %>
      <div style="display: flex; align-items: center; padding: 1rem; <%= index > 0 ? 'border-top: 1px solid var(--border-color);' : '' %>">
        <div style="width: 40px; height: 40px; border-radius: 10px; background: <%= consultation.status === 'active' ? 'linear-gradient(135deg, #22c55e 0%, #16a34a 100%)' : 'rgba(100, 100, 100, 0.2)'; %>; display: flex; align-items: center; justify-content: center; color: <%= consultation.status === 'active' ? 'white' : '#666'; %>; margin-right: 1rem;">
          <i class="fa-solid <%= consultation.status === 'active' ? 'fa-user-md' : 'fa-check' %>"></i>
        </div>
        <div style="flex: 1;">
          <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
            <strong><%= consultation.disease %></strong>
            <span style="font-size: 0.75rem; padding: 0.125rem 0.5rem; border-radius: 20px; background: <%= consultation.status === 'active' ? 'rgba(34, 197, 94, 0.1)' : 'rgba(100, 100, 100, 0.1)'; %>; color: <%= consultation.status === 'active' ? '#22c55e' : '#666'; %>;">
              <%= consultation.status === 'active' ? 'Active' : 'Completed' %>
            </span>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.9rem;">
            <i class="fa-solid fa-user-doctor me-1"></i><%= consultation.doctorName %> | 
            <%= new Date(consultation.startDate).toLocaleDateString() %>
            <% if (consultation.endDate) { %>
              - <%= new Date(consultation.endDate).toLocaleDateString() %>
            <% } %>
          </p>
        </div>
        <% if (consultation.status === 'active' && consultation.prescriptions && consultation.prescriptions.length > 0) { %>
          <div style="font-size: 0.85rem; color: var(--text-secondary);">
            <%= consultation.prescriptions.length %> prescription(s)
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
  <% } %>

  <!-- End Consultation Button (if active) -->
  <% if (activeConsultation) { %>
  <div style="margin-top: 1.5rem;">
    <form method="post" action="/end-consultation/<%= patient._id %>" onsubmit="return confirm('Are you sure you want to end this consultation? This will move it to history.');">
      <button type="submit" class="btn" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border: none; padding: 0.75rem 1.5rem; border-radius: 12px; color: white; font-weight: 600; cursor: pointer;">
        <i class="fa-solid fa-stop me-2"></i>End Current Consultation
      </button>
    </form>
  </div>
  <% } %>
</div>

