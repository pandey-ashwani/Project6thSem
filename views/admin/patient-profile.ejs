<% layout("layouts/admin/boilerplate.ejs") %>

<div class="doctor-profile-container">
  <!-- Detail Header Card -->
  <div class="profile-header-card">
    <div class="profile-avatar-section">
      <div class="profile-avatar" style="background: linear-gradient(135deg, #0ea5e9 0%, #14b8a6 100%);">
        <i class="fa-solid fa-user-injured"></i>
      </div>
      <div class="profile-title">
        <h2><%= patient.name %></h2>
        <span class="profile-badge" style="background: linear-gradient(135deg, #0ea5e9 0%, #14b8a6 100%);">Patient</span>
      </div>
    </div>
    <button type="button" class="btn-edit" data-bs-toggle="modal" data-bs-target="#editPatientModal">
      <i class="fa-solid fa-pen-to-square"></i> Update
    </button>
  </div>

  <!-- Info Grid -->
  <div class="profile-section-title">Patient Information</div>
  <div class="profile-info-grid">
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-user"></i>
      </div>
      <div class="info-content">
        <label>Name</label>
        <p><%= patient.name %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-cake-candles"></i>
      </div>
      <div class="info-content">
        <label>Age</label>
        <p><%= patient.age %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-phone"></i>
      </div>
      <div class="info-content">
        <label>Contact Number</label>
        <p><%= patient.username %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-virus"></i>
      </div>
      <div class="info-content">
        <label>Disease</label>
        <p><%= patient.disease || 'N/A' %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-user-doctor"></i>
      </div>
      <div class="info-content">
        <label>Doctor</label>
        <p><%= doctor.name %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-hospital"></i>
      </div>
      <div class="info-content">
        <label>Hospital</label>
        <p><%= patient.hospital %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-location-dot"></i>
      </div>
      <div class="info-content">
        <label>District</label>
        <p><%= patient.district %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;">
        <i class="fa-solid fa-map"></i>
      </div>
      <div class="info-content">
        <label>State</label>
        <p><%= doctor.state || 'N/A' %></p>
      </div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editPatientModal" tabindex="-1" aria-labelledby="editPatientModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editPatientModalLabel">
          <i class="fa-solid fa-pen-to-square me-2"></i>Update Patient
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="#" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" class="form-control" value="<%= patient.name %>">
          </div>
          <div class="mb-3">
            <label class="form-label">Age</label>
            <input type="number" class="form-control" value="<%= patient.age %>">
          </div>
          <div class="mb-3">
            <label class="form-label">Contact Number</label>
            <input type="text" class="form-control" value="<%= patient.username %>">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

