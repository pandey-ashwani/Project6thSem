<% layout("/layouts/doctor/boilerplate.ejs") %>

<div class="doctor-profile-container">
  <!-- Profile Header Card -->
  <div class="profile-header-card">
    <div class="profile-avatar-section">
      <div class="profile-avatar">
        <i class="fa-solid fa-user-doctor"></i>
      </div>
      <div class="profile-title">
        <h2><%= doctor.name %></h2>
        <span class="profile-badge"><%= doctor.specialization %></span>
      </div>
    </div>
    <button class="btn-edit" data-bs-toggle="modal" data-bs-target="#editProfileModal">
      <i class="fa-solid fa-pen-to-square"></i> Edit Profile
    </button>
  </div>

  <!-- Personal Info Grid -->
  <div class="profile-section-title">Personal Information</div>
  <div class="profile-info-grid">
    <div class="info-card">
      <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
      <div class="info-content">
        <label>Email</label>
        <p><%= doctor.email %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
      <div class="info-content">
        <label>Contact Number</label>
        <p><%= doctor.phone %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon"><i class="fa-solid fa-graduation-cap"></i></div>
      <div class="info-content">
        <label>Qualifications</label>
        <p><%= doctor.qualification %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon"><i class="fa-solid fa-briefcase-medical"></i></div>
      <div class="info-content">
        <label>Experience</label>
        <p><%= doctor.experience %> Years</p>
      </div>
    </div>
  </div>

  <!-- Hospital Details -->
  <div class="profile-section-title">Hospital Details</div>
  <div class="profile-info-grid">
    <div class="info-card">
      <div class="info-icon"><i class="fa-solid fa-hospital"></i></div>
      <div class="info-content">
        <label>Hospital</label>
        <p><%= doctor.hospital %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
      <div class="info-content">
        <label>District</label>
        <p><%= doctor.district %></p>
      </div>
    </div>
    <div class="info-card">
      <div class="info-icon"><i class="fa-solid fa-map"></i></div>
      <div class="info-content">
        <label>State</label>
        <p><%= doctor.state %></p>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="profile-actions">
    <a href="/logout" class="btn-logout">
      <i class="fa-solid fa-right-from-bracket"></i> Log Out
    </a>
  </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1" aria-labelledby="editProfileModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editProfileModalLabel">
          <i class="fa-solid fa-pen-to-square me-2"></i>Edit Profile
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/doctor-profile/update" method="POST">
        <div class="modal-body">
          <div class="form-group mb-3">
            <label for="name" class="form-label">Full Name</label>
            <input type="text" class="form-control" id="name" name="name" value="<%= doctor.name %>" required>
          </div>
          <div class="form-group mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" class="form-control" id="email" name="email" value="<%= doctor.email %>" required>
          </div>
          <div class="form-group mb-3">
            <label for="phone" class="form-label">Contact Number</label>
            <input type="number" class="form-control" id="phone" name="phone" value="<%= doctor.phone %>" required>
          </div>
          <div class="form-group mb-3">
            <label for="specialization" class="form-label">Specialization</label>
            <input type="text" class="form-control" id="specialization" name="specialization" value="<%= doctor.specialization %>" required>
          </div>
          <div class="form-group mb-3">
            <label for="qualification" class="form-label">Qualifications</label>
            <input type="text" class="form-control" id="qualification" name="qualification" value="<%= doctor.qualification %>" required>
          </div>
          <div class="form-group mb-3">
            <label for="experience" class="form-label">Experience (Years)</label>
            <input type="number" class="form-control" id="experience" name="experience" value="<%= doctor.experience %>" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-check me-1"></i>Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

