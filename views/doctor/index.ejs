<% layout("/layouts/doctor/boilerplate.ejs") %>

<!-- Doctor Hero Welcome -->
<section class="doctor-hero">
  <h1>Welcome Back, Doctor</h1>
  <p class="subtitle">Your personalized dashboard for efficient patient management and seamless appointments</p>
  
  <div class="stats">
    <div class="stat-item">
      <span class="stat-number">12</span>
      <span class="stat-label">Today's Appointments</span>
    </div>
    <div class="stat-item">
      <span class="stat-number">5</span>
      <span class="stat-label">Upcoming</span>
    </div>
    <div class="stat-item">
      <span class="stat-number">24</span>
      <span class="stat-label">Active Patients</span>
    </div>
  </div>
</section>

<!-- Dashboard Cards -->
<section class="doctor-dashboard">
  <!-- Today's Appointments -->
  <div class="dashboard-card today-appts">
    <div class="card-icon">
      <i class="fas fa-calendar-check"></i>
    </div>
    <h3 class="card-title">Today's Appointments</h3>
    <p class="card-description">Manage your scheduled consultations for today. 12 patients awaiting your expertise.</p>
    <a href="/doctor-patient-appointment" class="btn-dashboard">
      <i class="fas fa-arrow-right"></i>
      View Appointments
    </a>
  </div>

  <!-- Upcoming Appointments -->
  <div class="dashboard-card upcoming-appts">
    <div class="card-icon">
      <i class="fas fa-calendar-days"></i>
    </div>
    <h3 class="card-title">Upcoming Appointments</h3>
    <p class="card-description">Stay ahead with appointments scheduled for the coming week. Plan your schedule effectively.</p>
    <a href="/doctor-upcoming-appointment" class="btn-dashboard">
      <i class="fas fa-arrow-right"></i>
      View Schedule
    </a>
  </div>

  <!-- Patient History -->
  <div class="dashboard-card patient-history">
    <div class="card-icon">
      <i class="fas fa-clock-rotate-left"></i>
    </div>
    <h3 class="card-title">Patient History</h3>
    <p class="card-description">Access complete medical history and treatment records for all your patients instantly.</p>
    <a href="/doctor-patient-history" class="btn-dashboard">
      <i class="fas fa-arrow-right"></i>
      View History
    </a>
  </div>

  <!-- Quick Actions -->
  <div class="dashboard-card quick-actions">
    <div class="card-icon">
      <i class="fas fa-layer-group"></i>
    </div>
    <h3 class="card-title">Quick Actions</h3>
    <p class="card-description">Fast access to essential tools</p>
    
    <div class="quick-actions-grid">
      <a href="/doctor-prescription" class="quick-action-btn">
        <i class="fas fa-prescription-bottle"></i>
        <span>New Prescription</span>
      </a>
      <a href="#" class="quick-action-btn">
        <i class="fas fa-file-medical"></i>
        <span>Patient Notes</span>
      </a>
      <a href="#" class="quick-action-btn">
        <i class="fas fa-stethoscope"></i>
        <span>Lab Results</span>
      </a>
      <a href="#" class="quick-action-btn">
        <i class="fas fa-chart-line"></i>
        <span>Reports</span>
      </a>
    </div>
  </div>
</section>
