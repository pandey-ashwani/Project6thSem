<% if(success && success.length) {%>
    <div class="row">
        <div class="alert alert-success alert-dismissible fade show col-6 offset-3 mt-2 " style="text-align: center;" role="alert">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        
    </div>
    <%}%>
    
    <% if(error && error.length) {%>
        <div class="row">
            <div class="alert alert-danger alert-dismissible fade show col-6 offset-3 mt-2 " style="text-align: center;" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            
        </div>
        <%}%>