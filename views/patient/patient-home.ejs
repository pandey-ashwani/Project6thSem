<% layout("layouts/patient/boilerplate.ejs") %>
<body>
    <div class="patientContainer">

        

<div class="patient-dashboard-hero">
  <div class="hero-shapes"></div>
  <h1 class="patient-hero-title">Welcome Back<span>, Patient!</span></h1>
  <p class="patient-hero-subtitle">Your personalized health dashboard. Track appointments, view prescriptions, and connect with top doctors 24/7.</p>
  <div class="cta-buttons">
    <button class="btn-primary-patient"><i class="fas fa-calendar-check me-2"></i>Book Appointment</button>
    <button class="btn-outline-patient"><i class="fas fa-chart-line me-2"></i>View History</button>
  </div>
</div>

<!-- Stats -->
<div class="patient-stats-grid">
  <div class="stat-card">
    <div class="stat-icon">
      <i class="fas fa-calendar-alt"></i>
    </div>
    <span class="stat-number" data-target="12">0</span>
    <span class="stat-label">Upcoming Appointments</span>
  </div>
  <div class="stat-card">
    <div class="stat-icon">
      <i class="fas fa-prescription-bottle-alt"></i>
    </div>
    <span class="stat-number" data-target="8">0</span>
    <span class="stat-label">Active Prescriptions</span>
  </div>
  <div class="stat-card">
    <div class="stat-icon">
      <i class="fas fa-users"></i>
    </div>
    <span class="stat-number" data-target="5">0</span>
    <span class="stat-label">Favorite Doctors</span>
  </div>
  <div class="stat-card">
    <div class="stat-icon">
      <i class="fas fa-clock"></i>
    </div>
    <span class="stat-number" data-target="45">0</span>
    <span class="stat-label">Total Visits</span>
  </div>
</div>

<!-- Features -->
<section class="patient-features">
  <h2 class="features-title">Why Choose SwasthyaSankalp?</h2>
  <p class="features-subtitle">Everything you need for seamless healthcare, available at your fingertips.</p>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">
        <i class="fas fa-video"></i>
      </div>
      <h3 class="feature-title">Video Consultations</h3>
      <p class="feature-desc">Connect with doctors instantly via secure video calls from anywhere, anytime.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">
        <i class="fas fa-pills"></i>
      </div>
      <h3 class="feature-title">Digital Prescriptions</h3>
      <p class="feature-desc">Get e-prescriptions instantly and order medicines with one tap.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">
        <i class="fas fa-file-medical-alt"></i>
      </div>
      <h3 class="feature-title">Health Records</h3>
      <p class="feature-desc">Complete medical history accessible anytime, anywhere on any device.</p>
    </div>
  </div>
</section>

<!-- Quick Actions -->
<section class="patient-quick-actions">
  <h2 class="actions-title">Quick Actions</h2>
  <div class="actions-grid">
    <div class="action-card">
      <div class="action-icon">
        <i class="fas fa-calendar-plus"></i>
      </div>
      <h3 class="action-title">New Appointment</h3>
    </div>
    <div class="action-card">
      <div class="action-icon">
        <i class="fas fa-video"></i>
      </div>
      <h3 class="action-title">Video Consult</h3>
    </div>
    <div class="action-card">
      <div class="action-icon">
        <i class="fas fa-prescription"></i>
      </div>
      <h3 class="action-title">Refill Medicine</h3>
    </div>
    <div class="action-card">
      <div class="action-icon">
        <i class="fas fa-file-alt"></i>
      </div>
      <h3 class="action-title">Lab Results</h3>
    </div>
    <div class="action-card">
      <div class="action-icon">
        <i class="fas fa-users"></i>
      </div>
      <h3 class="action-title">Find Doctor</h3>
    </div>
    <div class="action-card">
      <div class="action-icon">
        <i class="fas fa-phone"></i>
      </div>
      <h3 class="action-title">Emergency</h3>
    </div>
  </div>
</section>


    </div>
</body>
