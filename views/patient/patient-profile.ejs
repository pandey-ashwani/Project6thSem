<% layout("layouts/patient/boilerplate") %>
<div class="patient-profile-container">
  <!-- Profile Header Card -->
  <div class="profile-header-card">
    <div class="profile-avatar-section">
      <div class="profile-avatar patient-avatar">
        <i class="fa-solid fa-user-md"></i>
      </div>
      <div class="profile-title">
        <h2><%= patient.name %></h2>
        <span class="profile-badge patient-badge">Patient</span>
      </div>
    </div>
    <div class="profile-actions">
      <a href="#" class="btn btn-edit" data-bs-toggle="modal" data-bs-target="#editPatientModal">
        <i class="fa-solid fa-pen-to-square me-1"></i>Edit Profile
      </a>
    </div>
  </div>

  <!-- Profile Info Grid -->
  <div class="profile-info-grid">
    <div class="info-card">
      <div class="info-icon patient-icon">
        <i class="fa-solid fa-phone"></i>
      </div>
      <div class="info-content">
        <label>Contact</label>
        <p><%= patient.username %></p>
      </div>
    </div>

    <div class="info-card">
      <div class="info-icon patient-icon">
        <i class="fa-solid fa-calendar-days"></i>
      </div>
      <div class="info-content">
        <label>Age</label>
        <p><%= patient.age %> years</p>
      </div>
    </div>

    <div class="info-card">
      <div class="info-icon patient-icon">
        <i class="fa-solid fa-hospital"></i>
      </div>
      <div class="info-content">
        <label>Hospital</label>
        <p><%= patient.hospital %></p>
      </div>
    </div>

    <div class="info-card">
      <div class="info-icon patient-icon">
        <i class="fa-solid fa-map-location-dot"></i>
      </div>
      <div class="info-content">
        <label>District</label>
        <p><%= patient.district %></p>
      </div>
    </div>

    <div class="info-card">
      <div class="info-icon patient-icon">
        <i class="fa-solid fa-map-marker-alt"></i>
      </div>
      <div class="info-content">
        <label>State</label>
        <p><%= patient.state %></p>
      </div>
    </div>

    <div class="info-card">
      <div class="info-icon patient-icon">
        <i class="fa-solid fa-stethoscope"></i>
      </div>
      <div class="info-content">
        <label>Disease</label>
        <p><%= patient.disease %></p>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="profile-actions mt-4">
    <a href="/logout" class="btn btn-logout">
      <i class="fa-solid fa-right-from-bracket me-2"></i>Logout
    </a>
  </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editPatientModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <i class="fa-solid fa-pen-to-square me-2"></i>Edit Profile
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/patient-profile/update" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" class="form-control" name="name" value="<%= patient.name %>" required>
          </div>
          <div class="row">
            <div class="col-md-6">
              <label class="form-label">Age</label>
              <input type="number" class="form-control" name="age" value="<%= patient.age %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Contact</label>
              <input type="tel" class="form-control" name="username" value="<%= patient.username %>" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Disease</label>
            <input type="text" class="form-control" name="disease" value="<%= patient.disease %>" required>
          </div>
          <div class="row">
            <div class="col-md-6">
              <label class="form-label">District</label>
              <input type="text" class="form-control" name="district" value="<%= patient.district %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">State</label>
              <input type="text" class="form-control" name="state" value="<%= patient.state %>" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Hospital</label>
            <input type="text" class="form-control" name="hospital" value="<%= patient.hospital %>" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Update Profile</button>
        </div>
      </form>
    </div>
  </div>
</div>
