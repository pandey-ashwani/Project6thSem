<% layout("layouts/superAdmin/boilerplate.ejs") %>

<main>
    <!-- Dashboard Overview -->
    <section class="Policydashboard mt-4">
        <h2 class="text-center mb-4">
            <i class="fa-solid fa-chart-line me-2"></i>Dashboard Overview
        </h2>

        <div class="row g-4 justify-content-center">
            <% const cards = [
                { title: "Patients", icon: "fa-users", value: metrics.totalPatients },
                { title: "Doctors", icon: "fa-user-doctor", value: metrics.totalDoctors },
                { title: "Hospitals", icon: "fa-hospital", value: metrics.totalHospitals },
                { title: "Districts", icon: "fa-map-location-dot", value: metrics.totalDistricts },
                { title: "Diseases", icon: "fa-file-medical", value: metrics.totalDiseases },
                { title: "Policies", icon: "fa-shield-halved", value: metrics.activePolicies }
            ]; %>

            <% cards.forEach(card => { %>
                <div class="col-md-4 col-lg-2">
                    <div class="myCard text-center p-3">
                        <h5><i class="fa-solid <%= card.icon %> me-2"></i><%= card.title %></h5>
                        <p class="fs-4 fw-bold"><%= card.value %></p>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>

    <!-- Charts -->
    <section class="myDashboard mt-5">
        <h2><i class="fa-solid fa-chart-pie me-2"></i>Performance Metrics</h2>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center">Disease Distribution</h5>
                    <canvas id="diseaseChart"></canvas>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center">Hospital Patient Load</h5>
                    <canvas id="hospitalChart"></canvas>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center">District-wise Patients</h5>
                    <canvas id="districtChart"></canvas>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center">Monthly Registration Trend</h5>
                    <canvas id="monthlyChart"></canvas>
                </div>
            </div>
        </div>
    </section>

    <!-- Filters -->
    <section class="filters mt-5">
        <h2><i class="fa-solid fa-filter me-2"></i>Filter Patients</h2>

        <div class="row g-3">
            <div class="col-md-3">
                <label>District</label>
                <select id="district" class="form-select">
                    <option value="all">All</option>
                    <% [...new Set(allPatients.map(p => p.district).filter(Boolean))].sort().forEach(d => { %>
                        <option value="<%= d %>"><%= d %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-3">
                <label>Hospital</label>
                <select id="hospital" class="form-select">
                    <option value="all">All</option>
                    <% [...new Set(allPatients.map(p => p.hospital).filter(Boolean))].sort().forEach(h => { %>
                        <option value="<%= h %>"><%= h %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-3">
                <label>Disease</label>
                <select id="disease" class="form-select">
                    <option value="all">All</option>
                    <% [...new Set(allPatients.map(p => p.disease).filter(Boolean))].sort().forEach(d => { %>
                        <option value="<%= d %>"><%= d %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end gap-2">
                <button id="filterBtn" class="btn btn-primary w-100">Apply</button>
                <button id="resetBtn" class="btn btn-outline-dark w-100">Reset</button>
            </div>
        </div>
    </section>

    <!-- Table -->
    <section class="myDashboard mt-5">
        <h2><i class="fa-solid fa-users me-2"></i>Patient List</h2>

        <p class="text-secondary">
            <span id="resultCount"><%= allPatients.length %></span> patients found
        </p>

        <div class="table-responsive">
            <table class="table table-striped" id="patientTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>District</th>
                        <th>Hospital</th>
                        <th>Disease</th>
                        <th>Age</th>
                    </tr>
                </thead>
                <tbody id="patientTableBody">
                    <% allPatients.forEach(p => { %>
                        <tr>
                            <td><%= p.name %></td>
                            <td><%= p.district || "N/A" %></td>
                            <td><%= p.hospital || "N/A" %></td>
                            <td><%= p.disease || "N/A" %></td>
                            <td><%= p.age || "N/A" %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <p id="noResults" class="text-center text-secondary mt-3" style="display:none;">
            No patients match the selected filters
        </p>
    </section>

    <!-- JSON DATA (IMPORTANT FOR CHARTS) -->
    <script type="application/json" id="diseaseData"><%= JSON.stringify(charts.diseases) %></script>
    <script type="application/json" id="hospitalData"><%= JSON.stringify(charts.hospitals) %></script>
    <script type="application/json" id="districtData"><%= JSON.stringify(charts.districts) %></script>
    <script type="application/json" id="monthlyData"><%= JSON.stringify(charts.monthly) %></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
    document.addEventListener("DOMContentLoaded", () => {

        // FILTER
        const filterBtn = document.getElementById("filterBtn");
        const resetBtn = document.getElementById("resetBtn");

        filterBtn.addEventListener("click", filterPatients);
        resetBtn.addEventListener("click", resetFilters);

        function filterPatients() {
            const district = document.getElementById("district").value.toLowerCase();
            const hospital = document.getElementById("hospital").value.toLowerCase();
            const disease = document.getElementById("disease").value.toLowerCase();

            const rows = document.querySelectorAll("#patientTableBody tr");
            let count = 0;

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                const match =
                    (district === "all" || text.includes(district)) &&
                    (hospital === "all" || text.includes(hospital)) &&
                    (disease === "all" || text.includes(disease));

                row.style.display = match ? "" : "none";
                if (match) count++;
            });

            document.getElementById("resultCount").textContent = count;
            document.getElementById("noResults").style.display = count === 0 ? "block" : "none";
            document.getElementById("patientTable").style.display = count === 0 ? "none" : "table";
        }

        function resetFilters() {
            document.getElementById("district").value = "all";
            document.getElementById("hospital").value = "all";
            document.getElementById("disease").value = "all";
            filterPatients();
        }

        // CHARTS
        function getJson(id) {
            return JSON.parse(document.getElementById(id).textContent);
        }

        const colors = ['#0f766e','#3b82f6','#8b5cf6','#f59e0b','#ef4444'];

        new Chart(document.getElementById('diseaseChart'), {
            type: 'doughnut',
            data: {
                labels: Object.keys(getJson('diseaseData')),
                datasets: [{ data: Object.values(getJson('diseaseData')), backgroundColor: colors }]
            }
        });

        new Chart(document.getElementById('hospitalChart'), {
            type: 'bar',
            data: {
                labels: Object.keys(getJson('hospitalData')),
                datasets: [{ data: Object.values(getJson('hospitalData')) }]
            }
        });

        new Chart(document.getElementById('districtChart'), {
            type: 'pie',
            data: {
                labels: Object.keys(getJson('districtData')),
                datasets: [{ data: Object.values(getJson('districtData')), backgroundColor: colors }]
            }
        });

        new Chart(document.getElementById('monthlyChart'), {
            type: 'line',
            data: {
                labels: Object.keys(getJson('monthlyData')),
                datasets: [{ data: Object.values(getJson('monthlyData')), fill: true }]
            }
        });

    });
    </script>

</main>