<% layout("layouts/superAdmin/boilerplate.ejs") %>

<main>
    <!-- Dashboard Overview -->
    <section class="Policydashboard mt-4">
        <h2 class="text-center mb-4"><i class="fa-solid fa-chart-line me-2"></i>Dashboard Overview</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4 col-lg-2">
                <div class="myCard">
                    <h3><i class="fa-solid fa-users me-2"></i>Patients</h3>
                    <p><%= metrics.totalPatients %></p>
                </div>
            <div class="col-md-4 col-lg-2">
                <div class="myCard">
                    <h3><i class="fa-solid fa-user-doctor me-2"></i>Doctors</h3>
                    <p><%= metrics.totalDoctors %></p>
                </div>
            <div class="col-md-4 col-lg-2">
                <div class="myCard">
                    <h3><i class="fa-solid fa-hospital me-2"></i>Hospitals</h3>
                    <p><%= metrics.totalHospitals %></p>
                </div>
            <div class="col-md-4 col-lg-2">
                <div class="myCard">
                    <h3><i class="fa-solid fa-map-location-dot me-2"></i>Districts</h3>
                    <p><%= metrics.totalDistricts %></p>
                </div>
            <div class="col-md-4 col-lg-2">
                <div class="myCard">
                    <h3><i class="fa-solid fa-file-medical me-2"></i>Diseases</h3>
                    <p><%= metrics.totalDiseases %></p>
                </div>
            <div class="col-md-4 col-lg-2">
                <div class="myCard">
                    <h3><i class="fa-solid fa-shield-halved me-2"></i>Policies</h3>
                    <p><%= metrics.activePolicies %></p>
                </div>
        </div>
    </section>

    <!-- Performance Metrics Charts -->
    <section id="metrics" class="myDashboard mt-5">
        <h2><i class="fa-solid fa-chart-pie me-2"></i>Performance Metrics</h2>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center mb-3">Disease Distribution</h5>
                    <canvas id="diseaseChart"></canvas>
                </div>
            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center mb-3">Hospital Patient Load</h5>
                    <canvas id="hospitalChart"></canvas>
                </div>
            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center mb-3">District-wise Patients</h5>
                    <canvas id="districtChart"></canvas>
                </div>
            <div class="col-md-6">
                <div class="card p-3">
                    <h5 class="text-center mb-3">Monthly Registration Trend</h5>
                    <canvas id="monthlyChart"></canvas>
                </div>
        </div>
    </section>

    <!-- Filters -->
    <section id="filters" class="filters mt-5">
        <h2><i class="fa-solid fa-filter me-2"></i>Filter Patients</h2>
        <div class="d-flex flex-wrap gap-3 align-items-end">
            <div>
                <label for="district">District:</label>
                <select id="district" class="form-select">
                    <option value="all">All Districts</option>
                    <% [...new Set(allPatients.map(p => p.district).filter(Boolean))].sort().forEach(d => { %>
                        <option value="<%= d %>"><%= d %></option>
                    <% }) %>
                </select>
            </div>
            <div>
                <label for="hospital">Hospital:</label>
                <select id="hospital" class="form-select">
                    <option value="all">All Hospitals</option>
                    <% [...new Set(allPatients.map(p => p.hospital).filter(Boolean))].sort().forEach(h => { %>
                        <option value="<%= h %>"><%= h %></option>
                    <% }) %>
                </select>
            </div>
            <div>
                <label for="disease">Disease:</label>
                <select id="disease" class="form-select">
                    <option value="all">All Diseases</option>
                    <% [...new Set(allPatients.map(p => p.disease).filter(Boolean))].sort().forEach(d => { %>
                        <option value="<%= d %>"><%= d %></option>
                    <% }) %>
                </select>
            </div>
            <button id="filterBtn" class="btn"><i class="fa-solid fa-magnifying-glass me-2"></i>Apply Filters</button>
            <button id="resetBtn" class="btn btn-outline-dark"><i class="fa-solid fa-rotate-left me-2"></i>Reset</button>
        </div>
    </section>

    <!-- Patient Table -->
    <section class="myDashboard mt-5">
        <h2><i class="fa-solid fa-users me-2"></i>Patient List</h2>
        <p class="text-secondary mb-3"><span id="resultCount"><%= allPatients.length %></span> patients found</p>
        <div class="table-responsive">
            <table id="patientTable" class="table">
                <thead>
                    <tr>
                        <th onclick="sortTable(0)">Patient Name <i class="fa-solid fa-sort ms-1"></i></th>
                        <th onclick="sortTable(1)">District <i class="fa-solid fa-sort ms-1"></i></th>
                        <th onclick="sortTable(2)">Hospital <i class="fa-solid fa-sort ms-1"></i></th>
                        <th onclick="sortTable(3)">Disease <i class="fa-solid fa-sort ms-1"></i></th>
                        <th onclick="sortTable(4)">Age <i class="fa-solid fa-sort ms-1"></i></th>
                    </tr>
                </thead>
                <tbody id="patientTableBody">
                    <% for(let patient of allPatients) { %>
                    <tr data-district="<%= patient.district || '' %>" data-hospital="<%= patient.hospital || '' %>" data-disease="<%= patient.disease || '' %>">
                        <td><%= patient.name %></td>
                        <td><%= patient.district || 'N/A' %></td>
                        <td><%= patient.hospital || 'N/A' %></td>
                        <td><%= patient.disease || 'N/A' %></td>
                        <td><%= patient.age || 'N/A' %></td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        <p id="noResults" class="text-center text-secondary mt-4" style="display: none;">
            <i class="fa-solid fa-circle-info me-2"></i>No patients match the selected filters.
        </p>
    </section>

    <!-- Policy Management -->
    <section id="policies" class="policy-interface">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="m-0"><i class="fa-solid fa-shield-halved me-2"></i>Policy Management</h2>
            <button onclick="openPolicyModal()"><i class="fa-solid fa-plus me-2"></i>Add New Policy</button>
        </div>
        <div class="table-responsive">
            <table class="table" id="policyTable">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Effective Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="policyTableBody">
                    <% for(let policy of allPolicies) { %>
                    <tr data-id="<%= policy._id %>">
                        <td><%= policy.title %></td>
                        <td><span class="badge bg-info"><%= policy.category %></span></td>
                        <td><span class="badge <%= policy.status === 'active' ? 'bg-success' : policy.status === 'draft' ? 'bg-warning' : 'bg-secondary' %>"><%= policy.status %></span></td>
                        <td><%= policy.effectiveDate ? new Date(policy.effectiveDate).toLocaleDateString() : 'N/A' %></td>
                        <td>
                            <button class="btn btn-sm btn-primary" onclick="editPolicy('<%= policy._id %>', '<%= policy.title %>', `<%= policy.description %>`, '<%= policy.category %>', '<%= policy.status %>')"><i class="fa-solid fa-pen"></i></button>
                            <button class="btn btn-sm btn-danger" onclick="deletePolicy('<%= policy._id %>')"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<!-- Policy Modal -->
<div class="modal fade" id="policyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="policyModalTitle">Add New Policy</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="policyForm">
                    <input type="hidden" id="policyId">
                    <div class="mb-3">
                        <label for="policyTitle" class="form-label">Policy Title</label>
                        <input type="text" class="form-control" id="policyTitle" required>
                    </div>
                    <div class="mb-3">
                        <label for="policyDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="policyDescription" rows="3" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="policyCategory" class="form-label">Category</label>
                        <select class="form-select" id="policyCategory" required>
                            <option value="Health">Health</option>
                            <option value="Finance">Finance</option>
                            <option value="Infrastructure">Infrastructure</option>
                            <option value="Emergency">Emergency</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="policyStatus" class="form-label">Status</label>
                        <select class="form-select" id="policyStatus" required>
                            <option value="active">Active</option>
                            <option value="draft">Draft</option>
                            <option value="archived">Archived</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="savePolicy()">Save Policy</button>
            </div>
    </div>

<!-- Chart Data -->
<script type="application/json" id="diseaseData"><%= JSON.stringify(charts.diseases) %></script>
<script type="application/json" id="hospitalData"><%= JSON.stringify(charts.hospitals) %></script>
<script type="application/json" id="districtData"><%= JSON.stringify(charts.districts) %></script>
<script type="application/json" id="monthlyData"><%= JSON.stringify(charts.monthly) %></script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Filter
    document.getElementById("filterBtn").addEventListener("click", filterPatients);
    document.getElementById("resetBtn").addEventListener("click", resetFilters);

    function filterPatients() {
        const district = document.getElementById("district").value.toLowerCase();
        const hospital = document.getElementById("hospital").value.toLowerCase();
        const disease = document.getElementById("disease").value.toLowerCase();
        const rows = document.querySelectorAll("#patientTableBody tr");
        let visibleCount = 0;

        rows.forEach(row => {
            const rowDistrict = (row.getAttribute("data-district") || "").toLowerCase();
            const rowHospital = (row.getAttribute("data-hospital") || "").toLowerCase();
            const rowDisease = (row.getAttribute("data-disease") || "").toLowerCase();

            const match = (district === "all" || rowDistrict === district) &&
                          (hospital === "all" || rowHospital === hospital) &&
                          (disease === "all" || rowDisease === disease);

            row.style.display = match ? "" : "none";
            if (match) visibleCount++;
        });

        document.getElementById("resultCount").textContent = visibleCount;
        document.getElementById("noResults").style.display = visibleCount === 0 ? "block" : "none";
        document.getElementById("patientTable").style.display = visibleCount === 0 ? "none" : "table";
    }

    function resetFilters() {
        document.getElementById("district").value = "all";
        document.getElementById("hospital").value = "all";
        document.getElementById("disease").value = "all";
        filterPatients();
    }

    // Sort
    let sortDirection = {};
    function sortTable(columnIndex) {
        const tbody = document.getElementById("patientTableBody");
        const rows = Array.from(tbody.querySelectorAll("tr"));
        sortDirection[columnIndex] = !sortDirection[columnIndex];
        const isAscending = sortDirection[columnIndex];

        rows.sort((a, b) => {
            const aVal = a.cells[columnIndex].textContent.trim().toLowerCase();
            const bVal = b.cells[columnIndex].textContent.trim().toLowerCase();
            const aNum = parseFloat(aVal), bNum = parseFloat(bVal);
            if (!isNaN(aNum) && !isNaN(bNum) && aVal !== '' && bVal !== '') {
                return isAscending ? aNum - bNum : bNum - aNum;
            }
            return isAscending ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
        });

        rows.forEach(row => tbody.appendChild(row));
        document.querySelectorAll("th i").forEach(icon => icon.className = "fa-solid fa-sort ms-1");
        const activeIcon = document.getElementById("patientTable").rows[0].cells[columnIndex].querySelector("i");
        activeIcon.className = isAscending ? "fa-solid fa-sort-up ms-1" : "fa-solid fa-sort-down ms-1";
    }

    // Policy Management
    const policyModal = new bootstrap.Modal(document.getElementById('policyModal'));

    function openPolicyModal() {
        document.getElementById('policyForm').reset();
        document.getElementById('policyId').value = '';
        document.getElementById('policyModalTitle').textContent = 'Add New Policy';
        policyModal.show();
    }

    function editPolicy(id, title, description, category, status) {
        document.getElementById('policyId').value = id;
        document.getElementById('policyTitle').value = title;
        document.getElementById('policyDescription').value = description;
        document.getElementById('policyCategory').value = category;
        document.getElementById('policyStatus').value = status;
        document.getElementById('policyModalTitle').textContent = 'Edit Policy';
        policyModal.show();
    }

    async function savePolicy() {
        const id = document.getElementById('policyId').value;
        const data = {
            title: document.getElementById('policyTitle').value,
            description: document.getElementById('policyDescription').value,
            category: document.getElementById('policyCategory').value,
            status: document.getElementById('policyStatus').value
        };

        try {
            const url = id ? `/api/policies/${id}` : '/api/policies';
            const method = id ? 'PUT' : 'POST';
            const response = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            if (result.success) {
                policyModal.hide();
                location.reload();
            } else {
                alert('Error: ' + result.error);
            }
        } catch (err) {
            alert('Error saving policy: ' + err.message);
        }
    }

    async function deletePolicy(id) {
        if (!confirm('Are you sure you want to delete this policy?')) return;
        try {
            const response = await fetch(`/api/policies/${id}`, { method: 'DELETE' });
            const result = await response.json();
            if (result.success) location.reload();
            else alert('Error: ' + result.error);
        } catch (err) {
            alert('Error deleting policy: ' + err.message);
        }
    }

    // Charts
    const chartColors = ['#0f766e', '#3b82f6', '#8b5cf6', '#f59e0b', '#ef4444', '#10b981', '#6366f1', '#ec4899', '#14b8a6', '#f97316'];

    function getJson(id) { return JSON.parse(document.getElementById(id).textContent); }

    const diseaseData = getJson('diseaseData');
    new Chart(document.getElementById('diseaseChart'), {
        type: 'doughnut',
        data: { labels: Object.keys(diseaseData), datasets: [{ data: Object.values(diseaseData), backgroundColor: chartColors, borderWidth: 2, borderColor: '#fff' }] },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });

    const hospitalData = getJson('hospitalData');
    new Chart(document.getElementById('hospitalChart'), {
        type: 'bar',
        data: { labels: Object.keys(hospitalData), datasets: [{ label: 'Patients', data: Object.values(hospitalData), backgroundColor: '#3b82f6', borderRadius: 8 }] },
        options: { responsive: true, scales: { y: { beginAtZero: true } } }
    });

    const districtData = getJson('districtData');
    new Chart(document.getElementById('districtChart'), {
        type: 'pie',
        data: { labels: Object.keys(districtData), datasets: [{ data: Object.values(districtData), backgroundColor: chartColors, borderWidth: 2, borderColor: '#fff' }] },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });

    const monthlyData = getJson('monthlyData');
    new Chart(document.getElementById('monthlyChart'), {
        type: 'line',
        data: {
            labels: Object.keys(monthlyData),
            datasets: [{ label: 'New Registrations', data: Object.values(monthlyData), borderColor: '#0f766e', backgroundColor: 'rgba(15, 118, 110, 0.1)', fill: true, tension: 0.4, pointRadius: 5, pointBackgroundColor: '#0f766e' }]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true } } }
    });
</script>
