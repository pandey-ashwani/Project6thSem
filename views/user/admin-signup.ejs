<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body style="padding-top: 0;">

    <button class="btn btn-success mt-3 ms-3" onclick="window.location.href='/'" >
        <i class="fa-solid fa-arrow-left-long mt-1 ms-1"></i> Back</button>

    <div class="container row" >
        <form method="post" action="/signup-admin" class="col-6 offset-4 form" style="margin-top: 70px;">

            <img src="logo.png" alt="Logo" width="100" class="logo-image " style="margin-left: 43%;">
            <h3 class="col-6 offset-4 signup-admin" style="margin-bottom: 60px;">Sign Up as Admin</h3><br/>

            
            <label for="username" class="form-label mt-3">Username:</label>

            <input type="text" name="username" id="username" class="form-control">
           
            <label for="name" class="form-label mt-3">Full Name:</label>
            <input type="text" name="name" id="name" class="form-control">

            <label for="email" class="form-label mt-3">Email:</label>
            <input type="text" name="email" id="email" class="form-control">

            <label for="phone" class="form-label mt-3">Contact Number:</label>
            <input type="text" name="phone" id="phone" class="form-control">

            <label for="district" class="form-label mt-3">District</label>
            <input type="text" name="district" id="district" class="form-control">

            <label for="state" class="form-label mt-3">State</label>
            <input type="text" name="state" id="state" class="form-control">

            <label for="hospital" class="form-label mt-3">Hospital:</label>
            <input type="text" name="hospital" id="hospital" class="form-control">

            <label for="password" class="form-label mt-3">Password</label>
            <input type="text" name="password" id="password" class="form-control">

            <button class="btn btn-outline-dark mt-4 mb-4">Sign Up</button>
            

        </form>
    </div>


    <div class="footerCont">
        <div>
        <a>&copy 2024 SwasthyaSankalp, Inc.</a>
        <a>Privacy</a>
        <a>Terms</a>
        </div>
        <div>
        <i class="fa-brands fa-square-facebook"></i>
        <i class="fa-brands fa-instagram"></i>
        <i class="fa-brands fa-linkedin"></i>
        </div>
    </div>

</body>
</html>