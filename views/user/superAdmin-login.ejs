<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin Log In</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        .login-wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 1rem;
        }
        .login-card {
            background: var(--bg-secondary, #ffffff);
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            width: 100%;
            max-width: 450px;
            margin: 0 auto;
        }
        .login-logo {
            display: block;
            margin: 0 auto 1rem;
            width: 100px;
            height: auto;
        }
        .login-title {
            text-align: center;
            margin-bottom: 2rem;
            font-weight: 600;
        }
        .btn-group-login {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }
        .btn-group-login > * {
            flex: 1 1 auto;
        }
        @media (max-width: 576px) {
            .login-card {
                padding: 1.25rem;
            }
            .btn-group-login {
                flex-direction: column;
            }
            .btn-group-login > * {
                width: 100%;
                margin: 0 !important;
            }
        }
    </style>
</head>
<body style="padding-top: 0;">

    <button class="btn btn-success mt-3 ms-3" onclick="window.location.href='/'">
        <i class="fa-solid fa-arrow-left-long mt-1 ms-1"></i> Back
    </button>

    <div class="login-wrapper">
        <div class="login-card">
            <form method="post" action="/superAdmin-login">
                <img src="logo.png" alt="Logo" class="login-logo">
                <h3 class="login-title">Log In as Super Admin</h3>

                <label for="username" class="form-label mt-3">Username</label>
                <input type="text" name="username" id="username" class="form-control" required>

                <label for="password" class="form-label mt-3">Password</label>
                <input type="password" name="password" id="password" class="form-control" required>

                <div class="btn-group-login">
                    <button class="btn btn-outline-dark" type="submit">Log In</button>
                    <a class="btn btn-secondary" href="/superAdmin-signup" style="text-decoration: none; color: black; background-color: white !important;">Register Here</a>
                </div>
            </form>
        </div>
    </div>

    <div class="footerCont">
        <div>
            <a>&copy; 2024 SwasthyaSankalp, Inc.</a>
            <a>Privacy</a>
            <a>Terms</a>
        </div>
        <div>
            <i class="fa-brands fa-square-facebook"></i>
            <i class="fa-brands fa-instagram"></i>
            <i class="fa-brands fa-linkedin"></i>
        </div>
    </div>

</body>
</html>
