<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SuperAdmin Login | SwasthyaSankalp</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/styles-superAdmin-login.css">
</head>
<body class="superadmin-login-page">
    
    <a href="/" class="superadmin-back-btn">
        <i class="fas fa-arrow-left"></i>
        Back to Home
    </a>

    <div class="superadmin-login-container">
        <div class="superadmin-login-card">
            <div class="superadmin-branding">
                <% if (typeof logoPath !== 'undefined') { %>
                    <div class="superadmin-logo">
                        <img src="<%= logoPath %>" alt="SwasthyaSankalp Logo">
                    </div>
                <% } else { %>
                    <div class="superadmin-logo">
                        <i class="fas fa-shield-alt fa-2x"></i>
                    </div>
                <% } %>
                <h1 class="superadmin-title">SuperAdmin Portal</h1>
                <p class="superadmin-subtitle">State Health Management System</p>
            </div>

            <% if (typeof messages !== 'undefined' && messages.error) { %>
                <div class="superadmin-error">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <%= messages.error %>
                </div>
            <% } %>

            <form method="POST" action="/superAdmin-login" id="superadmin-login-form" novalidate>
                <div class="superadmin-input-group">
                    <input 
                        type="text" 
                        id="username" 
                        name="username" 
                        class="superadmin-input form-control" 
                        placeholder=" " 
                        required 
                        autocomplete="username"
                        minlength="3"
                    >
                    <label for="username" class="superadmin-input-label">
                        <i class="fas fa-user me-1"></i>Username
                    </label>
                </div>

                <div class="superadmin-input-group">
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        class="superadmin-input form-control" 
                        placeholder=" " 
                        required 
                        autocomplete="current-password"
                        minlength="6"
                    >
                    <label for="password" class="superadmin-input-label">
                        <i class="fas fa-lock me-1"></i>Password
                    </label>
                    <button type="button" class="superadmin-password-toggle" tabindex="-1">
                        <i class="fas fa-eye-slash"></i>
                    </button>
                </div>

                <div class="superadmin-buttons">
                    <button type="submit" class="superadmin-btn superadmin-btn-primary">
                        <i class="fas fa-sign-in-alt"></i>
                        Log In
                        <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                    <a href="/superAdmin-signup" class="superadmin-btn superadmin-btn-secondary">
                        <i class="fas fa-user-plus"></i>
                        Create Account
                    </a>
                </div>
            </form>
        </div>

        <div class="superadmin-footer">
            <p>&copy; 2024 SwasthyaSankalp. All rights reserved | Government of India</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/superAdmin-login.js"></script>
</body>
</html>

    <div class="login-wrapper">
        <div class="login-card">
            <form method="post" action="/superAdmin-login">
                <img src="logo.png" alt="Logo" class="login-logo">
                <h3 class="login-title">Log In as Super Admin</h3>

                <label for="username" class="form-label mt-3">Username</label>
                <input type="text" name="username" id="username" class="form-control" required>

                <label for="password" class="form-label mt-3">Password</label>
                <input type="password" name="password" id="password" class="form-control" required>

                <div class="btn-group-login">
                    <button class="btn btn-outline-dark" type="submit">Log In</button>
                    <a class="btn btn-secondary" href="/superAdmin-signup" style="text-decoration: none; color: black; background-color: white !important;">Register Here</a>
                </div>
            </form>
        </div>
    </div>

    <div class="footerCont">
        <div>
            <a>&copy; 2024 SwasthyaSankalp, Inc.</a>
            <a>Privacy</a>
            <a>Terms</a>
        </div>
        <div>
            <i class="fa-brands fa-square-facebook"></i>
            <i class="fa-brands fa-instagram"></i>
            <i class="fa-brands fa-linkedin"></i>
        </div>
    </div>

</body>
</html>
